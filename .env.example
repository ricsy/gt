# Core authentication
GITEE_TOKEN=your_gitee_token

# Optional command defaults
# GT_HOST=gitee.com
# GT_REPO=gitee/demo-repo

# Optional temporary repo scope
# GT_REPO_SCOPE_MODE=org
# GT_REPO_SCOPE_NAMESPACE=gitee

# Optional live integration test settings
# GT_INTEGRATION_TESTS=1
# GT_TEST_OWNER=gitee
# GT_TEST_REPO=demo-repo
# GT_TEST_PR_BASE=main

# Optional nested env file indirection
# GT_ENV_FILE=.env.local
